@PACKAGE_INIT@

# StitchedConfig.cmake
# Configuration file for the Stitched package

# Include helper for finding dependencies
include(CMakeFindDependencyMacro)

# Compute paths
get_filename_component(Stitched_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)

# Add CMake module path for custom Find modules
list(APPEND CMAKE_MODULE_PATH "${Stitched_CMAKE_DIR}")

# Find all required dependencies that Stitched targets link against
# These must be found before including CMSSSWTargets.cmake

# Find Threads
find_dependency(Threads REQUIRED)

# Find Boost
find_dependency(Boost REQUIRED COMPONENTS program_options filesystem serialization)

# Find TBB
find_dependency(TBB REQUIRED)

# Find ROOT
find_dependency(ROOT REQUIRED COMPONENTS Core RIO Net Hist Tree)

# Find custom dependencies using our Find modules
#find_dependency(tinyxml2 REQUIRED) #not needed since is PRIVATE dependency
find_dependency(MD5 REQUIRED)
find_dependency(CLHEP REQUIRED)
#find_dependency(pybind11 REQUIRED) # not needed since is PRIVATE dependency

# Note: Python3, cpu_features and other dependencies may need to be found
# by the consuming project if they're used directly

# Include the targets file
include("${Stitched_CMAKE_DIR}/StitchedTargets.cmake")

# Include Stitched macros and utility functions
# StitchedMacros.cmake includes the path to edmWriteConfigs
include("${Stitched_CMAKE_DIR}/StitchedMacros.cmake")

# Set variables for compatibility
set(Stitched_INCLUDE_DIRS "@PACKAGE_INCLUDE_INSTALL_DIR@")
set(Stitched_LIBRARY_DIR "@PACKAGE_LIB_INSTALL_DIR@")

# Provide a list of available libraries/components
set(Stitched_LIBRARIES
    FWCoreUtilities
    FWCorePluginManager
    FWCoreReflection
    FWCoreVersion
    FWCoreParameterSet
    FWCoreParameterSetReader
    FWCorePythonParameterSet
    FWCoreServiceRegistry
    FWCoreMessageLogger
    FWCoreMessageService
    FWCoreAbstractServices
    FWCoreConcurrency
    FWCoreSharedMemory
    FWCoreCommon
    FWCoreFramework
    FWCoreSources
    FWCorePythonFramework
    FWCoreTestProcessor
    FWCoreServices
    FWCoreIntegration
    DataFormatsCommon
    DataFormatsProvenance
    DataFormatsTestObjects
)

# Check if requested components are available
if(Stitched_FIND_COMPONENTS)
    foreach(comp ${Stitched_FIND_COMPONENTS})
        if(NOT TARGET ${comp})
            if(Stitched_FIND_REQUIRED_${comp})
                message(FATAL_ERROR "Stitched component ${comp} not found")
            else()
                message(WARNING "Stitched component ${comp} not found")
            endif()
            set(Stitched_${comp}_FOUND FALSE)
        else()
            set(Stitched_${comp}_FOUND TRUE)
        endif()
    endforeach()
endif()

check_required_components(Stitched)

# Provide helpful information
message(STATUS "Found Stitched: ${Stitched_CMAKE_DIR}")
